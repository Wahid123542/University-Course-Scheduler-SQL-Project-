MariaDB [wsultani]> -- TASK 7: Associate Professors and Professors who teach
MariaDB [wsultani]> --         at least one section AND every section in their
MariaDB [wsultani]> --         dept's home building
MariaDB [wsultani]> -- ============================================================
MariaDB [wsultani]> SELECT p.PROF_NAME, p.RANK_TITLE AS PROF_RANK, d.DEPT_NAME, d.BUILDING AS DEPT_BUILDING
    -> FROM PROFESSOR p
    -> JOIN DEPT d ON p.DEPT_CODE = d.DEPT_CODE
    -> WHERE p.RANK_TITLE IN ('Professor', 'Associate Professor', 'Distinguished Professor')
    ->   AND p.PROF_ID IN (SELECT PROF_ID FROM SECTION)
    ->   AND p.PROF_ID NOT IN (
    ->         SELECT s.PROF_ID
    ->         FROM SECTION s
    ->         JOIN PROFESSOR p2 ON s.PROF_ID = p2.PROF_ID
    ->         JOIN DEPT d2 ON p2.DEPT_CODE = d2.DEPT_CODE
    ->         WHERE s.BUILDING <> d2.BUILDING
    ->       );
