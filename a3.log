MariaDB [wsultani]> -- TASK 6a: Open CSCE electives (COURSE_NUM >= 4000, >= 3 credits,
MariaDB [wsultani]> --          CURRENT_ENROLLMENT < MAX_ENROLLMENT)
MariaDB [wsultani]> -- ============================================================
MariaDB [wsultani]> SELECT s.COURSE_NUM, s.DEPT_CODE,
    ->        (s.MAX_ENROLLMENT - s.CURRENT_ENROLLMENT) AS SEATS_AVAILABLE
    -> FROM SECTION s
    -> JOIN COURSE c ON s.DEPT_CODE = c.DEPT_CODE AND s.COURSE_NUM = c.COURSE_NUM
    -> WHERE s.DEPT_CODE = 'CSCE'
    ->   AND s.COURSE_NUM >= '4000'
    ->   AND c.CREDIT >= 3
    ->   AND s.CURRENT_ENROLLMENT < s.MAX_ENROLLMENT;
